# ─────────────────────────────────────────────
# ReWear Backend — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# Database (Neon PostgreSQL)
# Get this from: https://neon.tech → Your Project → Connection String
DATABASE_URL="postgresql://USER:PASSWORD@HOST/rewear?sslmode=require"

# JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Cloudinary (Image Storage)
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend URL (for CORS)
# For local dev: http://localhost:3000 or file://
# For production: https://ritikamittal-19.github.io
FRONTEND_URL=https://ritikamittal-19.github.io

# Admin seed (optional — email of first admin user)
ADMIN_EMAIL=admin@rewear.com
